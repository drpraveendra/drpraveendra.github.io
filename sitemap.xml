---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:xhtml="http://www.w3.org/1999/xhtml">

  <!-- ══ MAIN PAGES ══ -->

  <url>
    <loc>{{ site.url }}/</loc>
    <lastmod>{{ site.time | date: "%Y-%m-%d" }}</lastmod>
    <changefreq>weekly</changefreq>
    <priority>1.0</priority>
  </url>

  {% for page in site.pages %}
    {% unless page.url == "/" or page.url contains "sitemap" or page.url contains "404" or page.url contains "feed" or page.sitemap == false %}
    <url>
      <loc>{{ site.url }}{{ page.url | replace: "index.html", "" }}</loc>
      <lastmod>{{ site.time | date: "%Y-%m-%d" }}</lastmod>
      <changefreq>monthly</changefreq>
      <priority>0.8</priority>
    </url>
    {% endunless %}
  {% endfor %}

  <!-- ══ BLOG POSTS (only published — future dates automatically excluded) ══ -->

  {% for post in site.posts %}
  <url>
    <loc>{{ site.url }}{{ post.url }}</loc>
    <lastmod>{{ post.date | date: "%Y-%m-%d" }}</lastmod>
    <changefreq>yearly</changefreq>
    <priority>0.8</priority>
    {% if post.lang_pair %}
    <xhtml:link rel="alternate" hreflang="{{ post.lang }}" href="{{ site.url }}{{ post.url }}"/>
    <xhtml:link rel="alternate" hreflang="{% if post.lang == 'en' %}hi{% else %}en{% endif %}" href="{{ site.url }}{{ post.lang_pair }}"/>
    {% endif %}
  </url>
  {% endfor %}

</urlset>
